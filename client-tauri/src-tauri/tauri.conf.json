{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "p2p-client",
  "version": "0.1.0",
  "identifier": "com.p2p.client",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "P2P Client",
        "width": 460,
        "height": 660,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"],
    "resources": ["bin/p2p-client"]
  }
}
